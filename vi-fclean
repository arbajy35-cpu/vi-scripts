#!/data/data/com.termux/files/usr/bin/bash

# ==========================================
# VI-FCLEAN PRO v13 - Professional Edition
# ==========================================

# ===== TERMUX CHECK =====
if [[ ! -d "/data/data/com.termux/files/usr" ]]; then
    echo "This tool works only in Termux."
    exit 1
fi

BASE_DIR="$HOME/.vifclean"
CONFIG="$BASE_DIR/config"
BACKUP_DIR="$BASE_DIR/backups"
LOG_FILE="$BASE_DIR/log.txt"
PREFIX="/data/data/com.termux/files/usr"

# ===== COLORS =====
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
RESET="\033[0m"

# ==========================================
# INSTALL MODE
# ==========================================
if [[ "$1" == "-install" ]]; then

    if [[ -f "$PREFIX/bin/vi-fclean" ]]; then
        echo -e "${YELLOW}Already installed.${RESET}"
        exit 0
    fi

    mkdir -p "$BASE_DIR" "$BACKUP_DIR"
    touch "$LOG_FILE"

    if [[ ! -f "$CONFIG" ]]; then
        echo "BACKUP=false" > "$CONFIG"
        echo "SAFE_MODE=true" >> "$CONFIG"
    fi

    cp "$0" "$PREFIX/bin/vi-fclean"
    chmod +x "$PREFIX/bin/vi-fclean"

    echo -e "${GREEN}✔ VI-FCLEAN installed successfully.${RESET}"
    exit 0
fi

# ==========================================
# LOAD CONFIG
# ==========================================
[[ -f "$CONFIG" ]] && source "$CONFIG"
BACKUP=${BACKUP:-false}
SAFE_MODE=${SAFE_MODE:-true}

# ==========================================
# BACKUP TOGGLE
# ==========================================
if [[ "$1" == "--backup-on" ]]; then
    sed -i 's/BACKUP=.*/BACKUP=true/' "$CONFIG"
    echo -e "${GREEN}✔ Backup Enabled.${RESET}"
    exit 0
fi

if [[ "$1" == "--backup-off" ]]; then
    sed -i 's/BACKUP=.*/BACKUP=false/' "$CONFIG"
    echo -e "${YELLOW}✔ Backup Disabled.${RESET}"
    exit 0
fi

# ==========================================
# HELP
# ==========================================
if [[ "$1" == "--help" ]]; then
    echo -e "${CYAN}VI-FCLEAN PRO v13${RESET}"
    echo
    echo "Usage:"
    echo "  vi-fclean file.sh"
    echo "  vi-fclean -r file.sh"
    echo "  vi-fclean -rm file.sh"
    echo "  vi-fclean --undo file.sh"
    echo
    echo "Options:"
    echo "  -install        Install tool"
    echo "  --backup-on     Enable backup"
    echo "  --backup-off    Disable backup"
    echo "  -force          Ignore safe mode"
    echo "  --help          Show help"
    exit 0
fi

# ==========================================
# UNDO
# ==========================================
if [[ "$1" == "--undo" ]]; then
    FILE="$2"
    NAME=$(basename "$FILE")
    LAST=$(ls -t "$BACKUP_DIR"/"$NAME".*.bak 2>/dev/null | head -n1)

    if [[ -z "$LAST" ]]; then
        echo -e "${RED}No backup found.${RESET}"
        exit 1
    fi

    cp "$LAST" "$FILE"
    echo -e "${GREEN}✔ Restored from backup.${RESET}"
    echo "[$(date)] UNDO $FILE" >> "$LOG_FILE"
    exit 0
fi

# ==========================================
# TARGET FILE
# ==========================================
FILE="${@: -1}"
[[ ! -f "$FILE" ]] && { echo -e "${RED}File not found.${RESET}"; exit 1; }

# ==========================================
# SAFE MODE
# ==========================================
if [[ "$SAFE_MODE" == "true" && "$1" != "-force" ]]; then
    if [[ "$FILE" == /etc/* || "$FILE" == /bin/* || "$FILE" == /usr/* ]]; then
        echo -e "${RED}Blocked by Safe Mode.${RESET}"
        echo -e "${YELLOW}Use -force to override.${RESET}"
        exit 1
    fi
fi

# ==========================================
# BACKUP FUNCTION
# ==========================================
create_backup() {
    if [[ "$BACKUP" == "true" ]]; then
        TS=$(date +%s)
        NAME=$(basename "$FILE")
        cp "$FILE" "$BACKUP_DIR/$NAME.$TS.bak"
        echo -e "${YELLOW}Backup created.${RESET}"
    fi
}

# ==========================================
# DOUBLE ENTER INPUT
# ==========================================
double_enter() {
    TMP=$(mktemp)
    EMPTY=0
    while IFS= read -r line; do
        if [[ -z "$line" ]]; then
            ((EMPTY++))
            [[ $EMPTY -ge 2 ]] && break
        else
            EMPTY=0
            echo "$line" >> "$TMP"
        fi
    done
    echo "$TMP"
}

# ==========================================
# REPLACE FULL
# ==========================================
replace_full() {
    create_backup
    echo "Paste content (Double ENTER to finish)"
    TMP=$(double_enter)
    mv "$TMP" "$FILE"
    echo -e "${GREEN}✔ File replaced.${RESET}"
    echo "[$(date)] REPLACE $FILE" >> "$LOG_FILE"
}

# ==========================================
# LINE MODE
# ==========================================
if [[ "$1" == "-rm" ]]; then

    echo "Replace full file or specific lines?"
    echo "1) Full file"
    echo "2) Specific lines"
    read -p "Choice: " C

    if [[ "$C" == "2" ]]; then

        read -p "Start line: " S
        read -p "End line: " E

        if ! [[ "$S" =~ ^[0-9]+$ && "$E" =~ ^[0-9]+$ && "$S" -le "$E" ]]; then
            echo -e "${RED}Invalid line numbers.${RESET}"
            exit 1
        fi

        create_backup

        echo "Paste new content (Double ENTER to finish)"
        TMP_NEW=$(double_enter)
        TMP_FINAL=$(mktemp)

        head -n $((S-1)) "$FILE" > "$TMP_FINAL"
        cat "$TMP_NEW" >> "$TMP_FINAL"
        tail -n +"$((E+1))" "$FILE" >> "$TMP_FINAL"

        mv "$TMP_FINAL" "$FILE"

        echo -e "${GREEN}✔ Lines replaced.${RESET}"
        echo "[$(date)] LINE_REPLACE $FILE $S-$E" >> "$LOG_FILE"

    else
        replace_full
    fi

    exit 0
fi

# ==========================================
# SIMPLE REPLACE
# ==========================================
if [[ "$1" == "-r" ]]; then
    replace_full
    exit 0
fi

# ==========================================
# CLEAR MODE
# ==========================================
read -p "Clear file? (y/n): " C
if [[ "$C" =~ ^[Yy]$ ]]; then
    create_backup
    : > "$FILE"
    echo -e "${GREEN}✔ File cleared.${RESET}"
    echo "[$(date)] CLEAR $FILE" >> "$LOG_FILE"
else
    echo "Cancelled."
fi
